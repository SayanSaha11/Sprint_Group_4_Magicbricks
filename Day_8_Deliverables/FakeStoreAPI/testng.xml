<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.1.dtd">
<suite name="FakeStore API Suite" verbose="1">

    <listeners>
        <listener class-name="utils.CustomHtmlReporter"/>
    </listeners>

    <test name="Auth">
        <classes><class name="tests.AuthTests"/></classes>
    </test>

    <test name="Products">
        <classes><class name="tests.ProductTests"/></classes>
    </test>

    <test name="Users">
        <classes><class name="tests.UserTests"/></classes>
    </test>

    <test name="Carts">
        <classes><class name="tests.CartTests"/></classes>
    </test>

</suite>
