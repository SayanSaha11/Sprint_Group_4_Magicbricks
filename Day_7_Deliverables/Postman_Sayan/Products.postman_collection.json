        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Status code name has OK\", function () {\r",
              "    pm.response.to.have.status(\"OK\");\r",
              "});\r",
              "pm.test(\"All products have valid ratings and prices\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    jsonData.forEach(function(product) {\r",
              "        pm.expect(product.price).to.be.above(0);\r",
              "        pm.expect(product.rating).to.have.property('rate');\r",
              "        pm.expect(product.rating).to.have.property('count');\r",
              "    });\r",
              "});"
            ],
