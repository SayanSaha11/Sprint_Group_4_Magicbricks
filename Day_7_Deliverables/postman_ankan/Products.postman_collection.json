              "    pm.expect(jsonData.id).to.not.be.null;\r",
              "    pm.expect(jsonData.id).to.eql(21);\r",
              "\r",
              "    pm.expect(jsonData.title).to.eql(\"Asics\");\r",
              "    pm.expect(jsonData.price).to.eql(10000);\r",
              "    pm.expect(jsonData.category).to.eql(\"Shoe\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is acceptable\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(800);\r",
              "});"
