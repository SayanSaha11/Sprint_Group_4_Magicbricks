      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Cart List Integrity\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "    pm.expect(jsonData.length).to.be.at.least(1);\r",
              "\r",
              "    var cartOne = jsonData.find(c => c.id === 1);\r",
              "    pm.expect(cartOne.userId).to.eql(1);\r",
              "    pm.expect(cartOne.date).to.include(\"2020-03-02\");\r",
              "\r",
              "    pm.expect(cartOne.products).to.be.an('array');\r",
              "    pm.expect(cartOne.products[0].productId).to.eql(1);\r",
              "    pm.expect(cartOne.products[0].quantity).to.eql(4);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
